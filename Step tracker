# Daily Steps Tracker Program

def main():
    # Function to set the user's daily step goal
    def set_steps_goal():
        goal = int(input("Enter your daily steps goal: "))
        return goal

    # Function to record steps for 7 days and calculate total
    def record_daily_steps():
        total_steps = 0

        # Loop 7 times (one for each day)
        for day in range(1, 8):
            steps = int(input(f"Enter steps for day {day}: "))
            total_steps += steps  # Add to running total

        return total_steps

    # Function to evaluate performance based on goal
    def evaluate_weekly_performance(total_steps, goal):
        # Calculate average steps
        average_steps = total_steps / 7

        # Display average
        print(f"\nYour average daily steps: {average_steps:.2f}")

        # Compare with goal
        if average_steps > goal:
            print(f"You exceeded your daily step goal of {goal} steps!")
        elif average_steps == goal:
            print(f"You met your daily step goal of {goal} steps!")
        else:
            print(f"You did not meet your daily step goal of {goal} steps.")


    # Step 1: Get goal
    goal = set_steps_goal()

    # Step 2: Record steps
    total_steps = record_daily_steps()

    # Step 3: Evaluate performance
    evaluate_weekly_performance(total_steps, goal)


# Run the program
main()
